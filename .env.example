# Flask runtime
FLASK_DEBUG=true

# Database configuration
# Preferred: a single URL (supports postgres://... and sqlite:///...)
DATABASE_URL=

# Fallback mode when DATABASE_URL is unset.
# Set to postgres to use DATABASE_* fields below; any other value uses SQLITE_PATH.
DATABASE_ENGINE=postgres
DATABASE_NAME=deadletter
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
SQLITE_PATH=deadletter.db

# CLI target API URL
API_URL=http://localhost:5000

# Alerting/observability
# Leave empty to disable Discord alerting.
DISCORD_WEBHOOK_URL=
PROMETHEUS_ENABLED=false
LOG_LEVEL=INFO
